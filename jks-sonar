pipeline {
    agent any

    environment {
        SONAR_SERVER = 'sonarqube-server'
        REPO_NAME = "${env.GIT_URL.split('/').last().split('\\.').first()}"
    }

    stages { 

        stage('Build y Sonar en paralelo') {
            parallel {
                stage('Compilar con Maven') {
                    agent {
                        docker {
                            image 'maven:3.8.4-openjdk-17-slim'
                            args '-u root'
                            reuseNode true
                        }
                    }
                    steps {
                        sh 'mvn clean package -DskipTests'
                        archiveArtifacts artifacts: 'target/*.jar', followSymlinks: false
                    }
                }

                stage('Análisis SonarQube') {
                    agent {
                        docker {
                            image 'maven:3.8.4-openjdk-17-slim'
                            args '-u root'
                            reuseNode true
                        }
                    }
                    steps {
                        withSonarQubeEnv("${env.SONAR_SERVER}") {
                            sh """
                                mvn sonar:sonar \
                                -Dsonar.organization=diego-armando \
                                -Dsonar.projectKey=${env.REPO_NAME} \
                                -Dsonar.projectName=${env.REPO_NAME} \
                                -Dsonar.sources=src/main/java 
                            """
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${env.REPO_NAME}:latest ."
                sh 'docker images'
            }
        }

    stage('Publish Docker Image') {
        steps {
    
            withCredentials([usernamePassword(
                credentialsId: 'dockerhub-credentials',
                usernameVariable: 'DOCKER_USER',
                passwordVariable: 'DOCKER_PASS'
            )]) {
    
                sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
    
                sh "docker tag 95-crud-clientes-java:latest $DOCKER_USER/95-crud-clientes-java:latest"
    
                sh "docker push $DOCKER_USER/95-crud-clientes-java:latest"
            }
        }
    }

    stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: true
            }
        }
    }

    post {
        success {
            echo "Compilación y análisis SonarQube exitosos."
        }

        failure {
            echo "El análisis de SonarQube falló o el Quality Gate no se cumplió."
        }
    }
}
